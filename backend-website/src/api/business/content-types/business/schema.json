{
  "kind": "collectionType",
  "collectionName": "businesses",
  "info": {
    "singularName": "business",
    "pluralName": "businesses",
    "displayName": "Business"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "description": {
      "type": "blocks"
    },
    "shortDescription": {
      "type": "string"
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "business",
        "service",
        "place"
      ]
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "verified": {
      "type": "boolean",
      "default": true
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "featured": {
      "type": "boolean",
      "default": true
    },
    "contact": {
      "type": "component",
      "component": "shared.contact",
      "repeatable": false
    },
    "location": {
      "type": "component",
      "component": "shared.location",
      "repeatable": false
    },
    "schedule": {
      "type": "component",
      "component": "shared.schedule",
      "repeatable": false
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    },
    "socialLinks": {
      "type": "component",
      "component": "shared.social-links",
      "repeatable": false
    },
    "area": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::area.area"
    },
    "categories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::category.category"
    },
    "businessModel": {
      "type": "enumeration",
      "enum": [
        "physical",
        "online",
        "both"
      ]
    },
    "acceptsCard": {
      "type": "boolean"
    },
    "homeDelivery": {
      "type": "boolean"
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "recomendando": {
      "type": "boolean"
    }
  }
}
