---
const currentYear = new Date().getFullYear();

const navLinks = [
  { label: "Inicio", href: "/" },
  { label: "Explorar", href: "/explorar" },
  { label: "Negocios", href: "/negocios" },
  { label: "Áreas", href: "/areas" },
  { label: "Categorías", href: "/categorias" },
];

const categories = [
  { label: "Restaurantes", href: "/categorias/restaurantes" },
  { label: "Cafeterías", href: "/categorias/cafeterias" },
  { label: "Hoteles", href: "/categorias/hoteles" },
  { label: "Dentistas", href: "/categorias/dentistas" },
  { label: "Veterinarias", href: "/categorias/veterinarias" },
  { label: "Gimnasios", href: "/categorias/gimnasios" },
  { label: "Farmacias", href: "/categorias/farmacias" },
  { label: "Estéticas", href: "/categorias/esteticas" },
];

const legalLinks = [
  // TODO: crear página /privacidad
  { label: "Privacidad", href: "/privacidad" },
  // TODO: crear página /terminos
  { label: "Términos de uso", href: "/terminos" },
  // TODO: crear página /registro
  { label: "Registra tu negocio", href: "/registro" },
];

const socials = [
  {
    name: "Facebook",
    href: "https://www.facebook.com/profile.php?id=61590639226998",
    path: "M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z",
  },
  {
    name: "WhatsApp",
    href: "https://wa.me/5215536411021?text=Hola,%20me%20interesa%20publicar%20mi%20negocio%20en%20Conoce%20Nicolás%20Romero",
    path: "M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z",
  },
];
---

<footer class="bg-gray-950 text-gray-400">
  <!-- Franja superior CTA -->
  <div class="border-b border-white/5">
    <div
      class="mx-auto max-w-7xl px-6 py-10 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between"
    >
      <div>
        <p class="text-base font-semibold text-white">
          ¿Tienes un negocio en Nicolás Romero?
        </p>
        <p class="mt-0.5 text-sm text-gray-400">
          Regístralo gratis y llega a miles de vecinos.
        </p>
      </div>
      <!-- TODO: crear página /registro -->
      <a
        href="/registro"
        class="inline-flex items-center gap-2 rounded-xl bg-primary px-5 py-2.5 text-sm font-semibold text-white transition hover:opacity-90 shrink-0"
      >
        Registrar mi negocio
        <svg
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </div>

  <!-- Cuerpo principal -->
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Col 1: Logo + descripción + redes -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-2 group">
          <!-- Reemplaza con tu logo real -->
          <div
            class="flex items-center justify-center rounded-lg  text-sm font-black"
          >
            <img
              src="/logo2.png"
              alt="Logo Descrubre NR"
              class="h-28 w-28 object-contain"
            />
          </div>
          <span class="text-base font-bold text-white"
            >NicolásRomero<span class="text-primary">.mx</span></span
          >
        </a>
        <p class="mt-4 text-sm leading-relaxed">
          Descubre lo mejor de Nicolás Romero. Negocios, servicios y lugares
          recomendados por vecinos como tú.
        </p>

        <!-- Redes sociales -->
        <div class="mt-6 flex gap-3">
          {
            socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={s.name}
                class="flex h-9 w-9 items-center justify-center rounded-xl bg-white/5 text-gray-400 transition hover:bg-white/10 hover:text-white"
              >
                <svg
                  class="h-4 w-4"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  viewBox="0 0 24 24"
                >
                  <path d={s.path} />
                </svg>
              </a>
            ))
          }
        </div>
      </div>

      <!-- Col 2: Navegación -->
      <div>
        <p
          class="mb-4 text-xs font-semibold uppercase tracking-widest text-gray-500"
        >
          Plataforma
        </p>
        <ul class="space-y-2.5">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm transition hover:text-white hover:translate-x-0.5 inline-block"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Col 3: Categorías -->
      <div>
        <p
          class="mb-4 text-xs font-semibold uppercase tracking-widest text-gray-500"
        >
          Categorías
        </p>
        <ul class="space-y-2.5">
          {
            categories.map((cat) => (
              <li>
                <a
                  href={cat.href}
                  class="text-sm transition hover:text-white hover:translate-x-0.5 inline-block"
                >
                  {cat.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Col 4: Municipio -->
      <div>
        <p
          class="mb-4 text-xs font-semibold uppercase tracking-widest text-gray-500"
        >
          Nicolás Romero
        </p>
        <ul class="space-y-2.5">
          <li class="flex items-start gap-2 text-sm">
            <svg
              class="h-4 w-4 mt-0.5 shrink-0 text-gray-500"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span>Estado de México, México</span>
          </li>
          <li class="flex items-start gap-2 text-sm">
            <svg
              class="h-4 w-4 mt-0.5 shrink-0 text-gray-500"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
              ></path>
            </svg>
            <span>+400,000 habitantes</span>
          </li>
          <li class="flex items-start gap-2 text-sm">
            <svg
              class="h-4 w-4 mt-0.5 shrink-0 text-gray-500"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
              ></path>
            </svg>
            <span>1,250+ negocios registrados</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Barra inferior -->
  <div class="border-t border-white/5">
    <div
      class="mx-auto max-w-7xl px-6 py-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"
    >
      <p class="text-xs text-gray-600">
        © {currentYear} NicolásRomero.mx — Hecho con ❤️ para el municipio
      </p>
      <div class="flex gap-4">
        {
          legalLinks.map((l) => (
            <a
              href={l.href}
              class="text-xs text-gray-600 transition hover:text-gray-400"
            >
              {l.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
