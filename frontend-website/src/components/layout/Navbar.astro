---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "Inicio", exact: true },
  { href: "/explorar", label: "Explorar" },
  { href: "/areas", label: "Áreas" },
  { href: "/categorias", label: "Categorías" },
  // { href: "/eventos", label: "Eventos" },
];

function isActive(href: string, exact?: boolean): boolean {
  if (exact) return currentPath === href;
  return currentPath === href || currentPath.startsWith(`${href}/`);
}

function linkClass(href: string, exact?: boolean): string {
  return isActive(href, exact)
    ? "font-medium text-primary"
    : "text-muted hover:text-primary";
}
---

<header
  class="sticky top-0 z-50 border-b border-border bg-white/80 backdrop-blur-xl"
>
  <div class="mx-auto flex h-18 max-w-7xl items-center justify-between gap-4 px-4 sm:px-6">
    <a href="/" class="flex min-w-0 items-center gap-2 sm:gap-3">
      <img
        src="/logo2.png"
        alt="Logo Descubre NR"
        class="h-14 w-14 shrink-0 object-contain sm:h-18 sm:w-18"
      />
      <div class="min-w-0">
        <p class="truncate font-semibold text-text">Nicolás Romero</p>
        <p class="truncate text-xs text-muted">Directorio Municipal</p>
      </div>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-8 md:flex" aria-label="Principal">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class={`transition-colors ${linkClass(link.href, link.exact)}`}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex shrink-0 items-center gap-2">
      <a
        href="/contacto"
        class="hidden rounded-2xl bg-primary px-4 py-2.5 text-sm font-medium text-white transition hover:bg-primary-hover sm:inline-flex sm:px-5 sm:py-3"
      >
        Contacto
      </a>

      <button
        type="button"
        id="mobileMenuBtn"
        class="inline-flex h-11 w-11 items-center justify-center rounded-xl border border-border text-text transition hover:bg-surface md:hidden"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobileMenu"
      >
        <svg
          id="mobileMenuIconOpen"
          class="h-5 w-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="mobileMenuIconClose"
          class="hidden h-5 w-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobileMenu"
    class="hidden border-t border-border bg-white md:hidden"
    aria-label="Menú móvil"
  >
    <nav class="mx-auto flex max-w-7xl flex-col gap-1 px-4 py-4 sm:px-6">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class={`mobile-nav-link rounded-xl px-4 py-3 text-base transition-colors ${linkClass(link.href, link.exact)}`}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/contacto"
        class="mobile-nav-link mt-2 rounded-2xl bg-primary px-4 py-3 text-center text-base font-medium text-white transition hover:bg-primary-hover"
      >
        Contacto
      </a>
    </nav>
  </div>
</header>

<script>
  function initMobileMenu() {
    const btn = document.getElementById("mobileMenuBtn");
    const menu = document.getElementById("mobileMenu");
    const iconOpen = document.getElementById("mobileMenuIconOpen");
    const iconClose = document.getElementById("mobileMenuIconClose");

    if (!btn || !menu || !iconOpen || !iconClose) return;

    if ((btn as any).__menuReady) return;
    (btn as any).__menuReady = true;

    const setOpen = (open: boolean) => {
      menu.classList.toggle("hidden", !open);
      btn.setAttribute("aria-expanded", String(open));
      btn.setAttribute("aria-label", open ? "Cerrar menú" : "Abrir menú");
      iconOpen.classList.toggle("hidden", open);
      iconClose.classList.toggle("hidden", !open);
      document.body.style.overflow = open ? "hidden" : "";
    };

    btn.addEventListener("click", () => {
      setOpen(menu.classList.contains("hidden"));
    });

    menu.querySelectorAll(".mobile-nav-link").forEach((link) => {
      link.addEventListener("click", () => setOpen(false));
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") setOpen(false);
    });

    document.addEventListener("astro:before-preparation", () => setOpen(false));
  }

  initMobileMenu();
  document.addEventListener("astro:page-load", initMobileMenu);
</script>
