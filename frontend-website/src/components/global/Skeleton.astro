---
// src/components/global/Skeleton.astro
// Placeholder de carga con efecto shimmer para secciones que esperan datos de Strapi.

interface Props {
  /** Número de skeletons a renderizar */
  count?: number;
  /** Tipo de skeleton: "card" (BusinessCard), "list" (fila compacta), "text" (párrafo) */
  type?: "card" | "list" | "text";
  /** Clase extra para el wrapper */
  class?: string;
}

const { count = 3, type = "card", class: extraClass = "" } = Astro.props;
---

<style>
  @keyframes shimmer {
    0%   { background-position: -1000px 0; }
    100% { background-position: 1000px 0; }
  }
  .skeleton-shimmer {
    background: linear-gradient(
      90deg,
      #f0f0f0 25%,
      #e0e0e0 50%,
      #f0f0f0 75%
    );
    background-size: 1000px 100%;
    animation: shimmer 1.6s infinite linear;
    border-radius: 0.5rem;
  }
</style>

{type === "card" && (
  <div class:list={["grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5", extraClass]}>
    {Array.from({ length: count }).map(() => (
      <div class="rounded-3xl border border-gray-100 bg-white overflow-hidden">
        <!-- Imagen -->
        <div class="skeleton-shimmer h-44 w-full"></div>
        <!-- Info -->
        <div class="px-4 pb-4 pt-7 space-y-2">
          <div class="skeleton-shimmer h-4 w-3/4"></div>
          <div class="skeleton-shimmer h-3 w-1/2"></div>
          <div class="skeleton-shimmer h-3 w-full mt-2"></div>
          <div class="skeleton-shimmer h-3 w-4/5"></div>
        </div>
      </div>
    ))}
  </div>
)}

{type === "list" && (
  <div class:list={["space-y-3", extraClass]}>
    {Array.from({ length: count }).map(() => (
      <div class="flex items-center gap-3 rounded-2xl border border-gray-100 bg-white p-4">
        <div class="skeleton-shimmer h-11 w-11 rounded-xl shrink-0"></div>
        <div class="flex-1 space-y-2">
          <div class="skeleton-shimmer h-3.5 w-2/3"></div>
          <div class="skeleton-shimmer h-3 w-1/3"></div>
        </div>
      </div>
    ))}
  </div>
)}

{type === "text" && (
  <div class:list={["space-y-2", extraClass]}>
    {Array.from({ length: count }).map((_, i) => (
      <div class:list={["skeleton-shimmer h-3", i === count - 1 ? "w-3/5" : "w-full"]}></div>
    ))}
  </div>
)}
