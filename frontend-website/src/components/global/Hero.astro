---
import { getFeaturedBusinesses } from "../../services/getFeaturedBussines/getfeaturedBussinnes";
import { getCategories } from "../../services/getCategories/getCategories";
import BusinessCard from "./BusinessCard.astro";
import SearchBar from "./SearchBar.astro";

const businesses = await getFeaturedBusinesses();
const categories = await getCategories();
const STRAPI_URL = import.meta.env.PUBLIC_STRAPI_URL;
---

<section class="py-10 sm:py-14 lg:min-h-screen lg:flex lg:items-center">
  <div class="mx-auto max-w-7xl w-full min-w-0 px-4 sm:px-6">
    <div class="grid min-w-0 items-start gap-10 lg:grid-cols-2 lg:gap-16">
      <!-- LEFT -->
      <div>
        <span
          class="inline-flex items-center gap-2 rounded-full border border-gray-200 bg-white px-4 text-sm font-medium text-gray-500 shadow-sm"
        >
          <span class="h-2 w-2 rounded-full bg-orange-500"></span>
          Descubre Nicolás Romero
        </span>

        <h1
          class="mt-5 text-3xl font-black tracking-tight sm:text-4xl md:text-5xl lg:text-6xl leading-[1.1]"
        >
          Encuentra lo mejor<br />
          de <span class="text-primary">tu ciudad</span>
        </h1>

        <p class="mt-5 max-w-md text-base leading-7 text-muted">
          Restaurantes, negocios y servicios recomendados por vecinos como tú.
        </p>

        <!-- Search -->
        <SearchBar
          variant="hero"
          class="mt-8 !mx-0 max-w-lg shadow-lg shadow-slate-100/80"
        />

        <!-- Categorías con chip visual tipo Airbnb -->
        <div class="hidden lg:block">
          <p
            class="mt-8 mb-3 text-xs font-semibold uppercase tracking-widest text-muted"
          >
            Categorías populares
          </p>
          <div class="flex gap-3 overflow-x-auto pb-2 scrollbar-hide">
            {
              categories.slice(0, 8).map((category) => (
                <a
                  href={`/categorias/${category.slug}`}
                  class="group relative shrink-0 w-36 h-24 rounded-2xl overflow-hidden border border-black/8 transition hover:-translate-y-0.5"
                >
                  {/* Imagen de fondo */}
                  <img
                    src={
                      category.image?.url
                        ? `${STRAPI_URL}${category.image.url}`
                        : "/images/placeholder-category.svg"
                    }
                    alt={category.name}
                    loading="lazy"
                    class="absolute inset-0 h-full w-full object-cover"
                  />
                  {/* Overlay */}
                  <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/10 to-transparent" />

                  {/* Nombre */}
                  <span class="absolute bottom-2 flex items-center gap-x-1 left-0 right-0 text-center text-[12px] font-medium text-white leading-tight px-1">
                    {category.icon?.url && (
                      <div class="">
                        <img
                          src={`${STRAPI_URL}${category.icon.url}`}
                          alt=""
                          class="h-7 w-7 bg-white rounded-full p-1 object-contain drop-shadow-sm"
                        />
                      </div>
                    )}{" "}
                    {category.name}
                  </span>
                </a>
              ))
            }
          </div>
        </div>

        <!-- Stats -->
        <div
          class="mt-8 hidden md:flex flex-wrap items-center gap-0 divide-x divide-border border-t border-border pt-7"
        >
          <div class="pr-8">
            <p class="text-2xl font-extrabold tracking-tight">1,250+</p>
            <p class="mt-0.5 text-xs text-muted">Negocios registrados</p>
          </div>
          <div class="px-8">
            <p class="text-2xl font-extrabold tracking-tight">85+</p>
            <p class="mt-0.5 text-xs text-muted">Categorías</p>
          </div>
          <div class="pl-8">
            <p class="text-2xl font-extrabold tracking-tight text-primary">
              4.8★
            </p>
            <p class="mt-0.5 text-xs text-muted">Calificación promedio</p>
          </div>
        </div>
      </div>

      <!-- RIGHT — cuadrícula 2×2 negocios destacados -->
      <div class="min-w-0 w-full">
        <div class="mb-4 flex items-center justify-between">
          <span
            class="inline-flex items-center gap-2 rounded-full border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-gray-500 shadow-sm"
          >
            <span class="h-2 w-2 rounded-full bg-emerald-500 animate-pulse"
            ></span>
            Mejor calificados hoy
          </span>
          <a
            href="/explorar"
            class="flex items-center gap-1 text-sm font-medium text-primary hover:opacity-80 transition-opacity"
          >
            Ver todos
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-3">
          {businesses.slice(0, 4).map((biz) => <BusinessCard business={biz} />)}
        </div>
      </div>
    </div>
  </div>
</section>
