---
interface Props {
  entries: [string, string][];
}

const { entries } = Astro.props;

const socialIcons: Record<string, string> = {
  facebook: "M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z",
  instagram: "M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37zm1.5-4.87h.01M6.5 19.5h11a3 3 0 003-3v-11a3 3 0 00-3-3h-11a3 3 0 00-3 3v11a3 3 0 003 3z",
  twitter: "M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z",
  tiktok: "M9 12a4 4 0 104 4V4a5 5 0 005 5",
  youtube: "M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z",
  whatsapp: "M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z",
  website: "M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14",
};

const socialColors: Record<string, { bg: string; text: string; hover: string }> = {
  facebook: { bg: "bg-[#1877F2]/10", text: "text-[#1877F2]", hover: "hover:bg-[#1877F2]/20" },
  instagram: { bg: "bg-pink-50", text: "text-pink-500", hover: "hover:bg-pink-100" },
  tiktok: { bg: "bg-gray-100", text: "text-gray-800", hover: "hover:bg-gray-200" },
  youtube: { bg: "bg-red-50", text: "text-red-500", hover: "hover:bg-red-100" },
  whatsapp: { bg: "bg-emerald-50", text: "text-emerald-600", hover: "hover:bg-emerald-100" },
  twitter: { bg: "bg-sky-50", text: "text-sky-500", hover: "hover:bg-sky-100" },
  website: { bg: "bg-violet-50", text: "text-violet-600", hover: "hover:bg-violet-100" },
};

const socialLabels: Record<string, string> = {
  facebook: "Facebook",
  instagram: "Instagram",
  tiktok: "TikTok",
  youtube: "YouTube",
  whatsapp: "WhatsApp",
  twitter: "Twitter / X",
  website: "Sitio web",
};
---

{
  entries.length > 0 && (
    <div class="rounded-3xl border border-gray-200 bg-white p-5 shadow-sm">
      <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-gray-400">Síguenos en</p>
      <div class="flex flex-col gap-2">
        {entries.map(([platform, url]) => {
          const href = url.startsWith("http") ? url : `https://${url}`;
          const iconPath = socialIcons[platform.toLowerCase()];
          const color = socialColors[platform.toLowerCase()] ?? {
            bg: "bg-gray-100",
            text: "text-gray-600",
            hover: "hover:bg-gray-200",
          };
          const label = socialLabels[platform.toLowerCase()] ?? platform;
          return (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class={`flex items-center gap-3 rounded-2xl px-4 py-2 transition-colors ${color.bg} ${color.hover}`}
            >
              <div class={`flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-white shadow-sm ${color.text}`}>
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                  <path d={iconPath ?? "M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"} />
                </svg>
              </div>
              <span class={`text-sm font-semibold ${color.text}`}>{label}</span>
              <svg class={`ml-auto h-4 w-4 opacity-40 ${color.text}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          );
        })}
      </div>
    </div>
  )
}
