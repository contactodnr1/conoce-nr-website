---
interface Props {
  paragraphs: string[];
}

const { paragraphs } = Astro.props;
---

{
  paragraphs.length > 0 && (
    <div class="border-b border-gray-100 pb-10">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Acerca del negocio</h2>
      <div class="space-y-3">
        {paragraphs.map((p) => (
          <p class="text-sm leading-relaxed text-gray-600">{p}</p>
        ))}
      </div>
    </div>
  )
}
