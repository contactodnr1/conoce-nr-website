---
interface Props {
  name: string;
  logo?: { url: string } | null;
  area?: { name: string } | null;
  location?: { address?: string | null } | null;
  categories?: { name: string; slug: string }[] | null;
  verified?: boolean | null;
  featured?: boolean | null;
  active?: boolean | null;
}

const { name, logo, area, location, categories, verified, featured, active } = Astro.props;

const STRAPI_URL = import.meta.env.PUBLIC_STRAPI_URL;

function img(url?: string | null): string {
  if (!url) return "/images/placeholder.svg";
  if (url.startsWith("http")) return url;
  return `${STRAPI_URL}${url}`;
}
---

<div class="flex items-start gap-4 border-b border-gray-100 pb-8">
  <img
    src={img(logo?.url)}
    alt={`Logo de ${name}`}
    class="h-16 w-16 md:h-20 md:w-20 shrink-0 rounded-2xl border border-gray-100 object-cover shadow-sm"
  />
  <div class="min-w-0 flex-1">
    <div class="flex items-center gap-2 flex-wrap mb-1">
      {
        verified && (
          <span class="inline-flex items-center gap-1 text-emerald-600 text-sm font-semibold">
            <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            Verificado
          </span>
        )
      }
      {
        featured && (
          <span class="text-amber-500 text-sm font-semibold">
            ⭐ Destacado
          </span>
        )
      }
    </div>
    <h1 class="text-2xl md:text-4xl font-bold text-gray-900 leading-tight">
      {name}
    </h1>
    <div class="mt-2 flex items-center gap-3 flex-wrap text-sm text-gray-500">
      {
        area?.name && (
          <span class="flex items-center gap-1">
            🏪 {area.name}
          </span>
        )
      }
      {
        location?.address && (
          <span class="text-gray-400">
            📍 {location.address}
          </span>
        )
      }
    </div>
    <div class="mt-3 flex flex-wrap gap-2">
      {
        categories?.map((cat) => (
          <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-600">
            {cat.name}
          </span>
        ))
      }
      <span
        class:list={[
          "inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium",
          active ? "bg-emerald-50 text-emerald-700" : "bg-gray-100 text-gray-500",
        ]}
      >
        <span
          class:list={[
            "h-1.5 w-1.5 rounded-full",
            active ? "bg-emerald-500" : "bg-gray-400",
          ]}></span>
        {active ? "Abierto ahora" : "Cerrado"}
      </span>
    </div>
  </div>
</div>
