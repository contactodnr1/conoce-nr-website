---
import Layout from "../../layouts/Layout.astro";
import { getAreas } from "../../services/getAreas/getAreas";
import { getBusinessesLight } from "../../services/businesses/getBusinessesLight";
import AreaCard from "../../components/layout/AreaCard.astro";
import EmptyState from "../../components/global/EmptyState.astro";
import { richTextToString } from "../../utils/richTextToString";

const [areas, businesses] = await Promise.all([
  getAreas(),
  getBusinessesLight(),
]);

const STRAPI_URL = import.meta.env.PUBLIC_STRAPI_URL;

function img(url?: string | null): string {
  if (!url) return "/images/placeholder-business.svg";
  if (url.startsWith("http")) return url;
  return `${STRAPI_URL}${url}`;
}

const areasWithCount = areas
  .map((area) => ({
    ...area,
    businessCount: businesses.filter((b) => b.area?.slug === area.slug).length,
  }))
  .sort((a, b) => b.businessCount - a.businessCount);

const totalBusinesses = businesses.length;
const featuredArea = areasWithCount[0];
const restAreas = areasWithCount.slice(1);
---

<Layout title="Áreas" description="Explora los negocios por área o colonia en Nicolás Romero, Estado de México. Encuentra servicios cerca de ti.">
  <!-- ░░ HERO ░░ -->
  <div class="mx-auto max-w-7xl px-4 pt-10 pb-6">
    <p
      class="text-xs font-semibold uppercase tracking-widest text-primary mb-2"
    >
      Explora por zona
    </p>
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-gray-900">
      Áreas de Nicolás Romero
    </h1>
    <p class="mt-3 max-w-2xl text-base text-gray-500">
      {areas.length} áreas que agrupan {totalBusinesses} negocios y servicios en todo
      el municipio.
    </p>
  </div>

  <div class="mx-auto max-w-7xl px-4 pb-16">
    <!-- ░░ ÁREA DESTACADA ░░ -->
    {
      featuredArea && (
        <a
          href={`/areas/${featuredArea.slug}`}
          class="group relative mb-10 block h-72 md:h-96 overflow-hidden rounded-3xl"
        >
          <img
            src={img(featuredArea.coverImage?.url)}
            alt={featuredArea.name}
            class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
          />

          <span class="absolute left-6 top-6 inline-flex items-center gap-1.5 rounded-full bg-white px-3.5 py-1.5 text-xs font-semibold text-gray-900 shadow-md z-10">
            🔥 La más popular
          </span>

          <div class="absolute right-6 top-6 z-10 rounded-2xl bg-white px-4 py-2 text-right shadow-md">
            <p class="text-2xl font-bold text-gray-900 leading-none">
              {featuredArea.businessCount}
            </p>
            <p class="text-[11px] text-gray-500 mt-0.5">
              {featuredArea.businessCount === 1 ? "negocio" : "negocios"}
            </p>
          </div>

          <div class="absolute bottom-0 left-0 right-0 h-32 md:h-36 bg-black/70 backdrop-blur-[2px]" />

          <div class="absolute bottom-0 left-0 right-0 p-5 md:p-7">
            <div class="flex items-center gap-4">
              {featuredArea.icon?.url && (
                <div class="flex h-12 w-12 md:h-14 md:w-14 shrink-0 items-center justify-center rounded-2xl bg-white shadow-lg">
                  <img
                    src={img(featuredArea.icon.url)}
                    alt={featuredArea.name}
                    class="h-7 w-7 md:h-8 md:w-8 object-contain"
                  />
                </div>
              )}
              <div class="min-w-0 flex-1">
                <h2 class="text-lg md:text-2xl font-bold text-white leading-tight truncate">
                  {featuredArea.name}
                </h2>
                <p class="mt-1 text-xs md:text-sm text-white/80 line-clamp-1 md:line-clamp-2">
                  {richTextToString(featuredArea.description)}
                </p>
              </div>
            </div>
          </div>
        </a>
      )
    }

    <!-- ░░ BARRA DE BÚSQUEDA + ORDEN ░░ -->
    <div
      class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"
    >
      <div class="relative flex-1 max-w-md">
        <svg
          class="absolute left-4 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        <input
          type="text"
          id="areaSearch"
          placeholder="Buscar área..."
          class="w-full rounded-full border border-gray-200 bg-white pl-11 pr-4 py-2.5 text-sm outline-none focus:border-gray-400 transition"
        />
      </div>

      <div class="flex items-center gap-2">
        <span
          class="text-xs font-medium text-gray-400 uppercase tracking-wide hidden sm:inline"
          >Ordenar</span
        >
        <select
          id="areaSort"
          class="rounded-full border border-gray-200 bg-white px-4 py-2.5 text-sm text-gray-700 outline-none focus:border-gray-400 transition cursor-pointer"
        >
          <option value="popular">Más negocios</option>
          <option value="alpha">Alfabético (A-Z)</option>
        </select>
      </div>
    </div>

    <!-- ░░ GRID DE ÁREAS ░░ -->
    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5"
      id="areasGrid"
    >
      {
        restAreas.map((area) => (
          <AreaCard area={area} businessCount={area.businessCount} />
        ))
      }
    </div>

    <!-- Empty state búsqueda -->
    <EmptyState
      id="emptySearch"
      icon="🔍"
      title="Sin resultados"
      description="No encontramos áreas con ese nombre."
      visible={false}
    />
  </div>
</Layout>

<script>
  const searchInput = document.getElementById("areaSearch") as HTMLInputElement;
  const sortSelect = document.getElementById("areaSort") as HTMLSelectElement;
  const grid = document.getElementById("areasGrid") as HTMLElement;
  const emptyState = document.getElementById("emptySearch");
  const cards = Array.from(
    document.querySelectorAll<HTMLElement>(".area-card"),
  );

  function filterAndSort() {
    const query = searchInput.value.trim().toLowerCase();
    let visible = 0;

    cards.forEach((card) => {
      const matches = card.dataset.name?.includes(query);
      card.style.display = matches ? "" : "none";
      if (matches) visible++;
    });

    emptyState?.classList.toggle("hidden", visible > 0);

    // Reordenar
    const sorted = [...cards].sort((a, b) => {
      if (sortSelect.value === "alpha") {
        return (a.dataset.name ?? "").localeCompare(b.dataset.name ?? "");
      }
      return Number(b.dataset.count) - Number(a.dataset.count);
    });
    sorted.forEach((card) => grid.appendChild(card));
  }

  searchInput?.addEventListener("input", filterAndSort);
  sortSelect?.addEventListener("change", filterAndSort);
</script>
