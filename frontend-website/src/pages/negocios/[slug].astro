            )
          }
        </div>
      </aside>
    </div>
  </div>

  <!-- ░░ MODAL GALERÍA ░░ -->
  {
    galleryImages.length > 0 && (
      <div
        id="galleryModal"
        class="fixed inset-0 z-50 hidden items-center justify-center bg-black/95 p-4"
        role="dialog"
        aria-modal="true"
