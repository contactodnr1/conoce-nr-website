---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import { getBusinessBySlug } from "../../services/businesses/getBusinessBySlug";

const { slug } = Astro.params;
const business = await getBusinessBySlug(slug!);

if (!business) return Astro.redirect("/404");

const STRAPI_URL = import.meta.env.PUBLIC_STRAPI_URL;

function img(url?: string | null): string {
  if (!url) return "/images/placeholder.svg";
  if (url.startsWith("http")) return url;
  return `${STRAPI_URL}${url}`;
}

function formatTime(t?: string | null): string {
  if (!t) return "—";
  const [h, m] = t.split(":");
  const hour = parseInt(h);
  const ampm = hour >= 12 ? "pm" : "am";
  const h12 = hour % 12 || 12;
  return `${h12}:${m} ${ampm}`;
}

const DAYS = [
  {
    label: "Lunes",
    open: business.schedule?.mondayOpen,
    close: business.schedule?.mondayClose,
  },
  {
    label: "Martes",
    open: business.schedule?.tuesdayOpen,
    close: business.schedule?.tuesdayClose,
  },
  {
    label: "Miércoles",
    open: business.schedule?.wednesdayOpen,
    close: business.schedule?.wednesdayClose,
  },
  {
    label: "Jueves",
    open: business.schedule?.thursdayOpen,
    close: business.schedule?.thursdayClose,
  },
  {
    label: "Viernes",
    open: business.schedule?.fridayOpen,
    close: business.schedule?.fridayClose,
  },
  {
    label: "Sábado",
    open: business.schedule?.saturdayOpen,
    close: business.schedule?.saturdayClose,
  },
  {
    label: "Domingo",
    open: business.schedule?.sundayOpen,
    close: business.schedule?.sundayClose,
  },
];

const todayIndex = new Date().getDay();
const dayMap = [6, 0, 1, 2, 3, 4, 5];
const todaySchedule = DAYS[dayMap[todayIndex]];

const descParagraphs =
  business.description
    ?.filter((block: any) => block.children?.[0]?.text?.trim())
    .map((block: any) => block.children.map((c: any) => c.text).join("")) ?? [];

const socialEntries = business.socialLinks
  ? Object.entries(business.socialLinks).filter(
      ([k, v]) => k !== "id" && typeof v === "string" && (v as string).trim(),
    )
  : [];

const socialIcons: Record<string, string> = {
  facebook: "M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z",
  instagram:
    "M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37zm1.5-4.87h.01M6.5 19.5h11a3 3 0 003-3v-11a3 3 0 00-3-3h-11a3 3 0 00-3 3v11a3 3 0 003 3z",
  twitter:
    "M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z",
  tiktok: "M9 12a4 4 0 104 4V4a5 5 0 005 5",
  youtube:
    "M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z",
  whatsapp:
    "M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z",
  website:
    "M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14",
};

const socialColors: Record<
  string,
  { bg: string; text: string; hover: string }
> = {
  facebook: {
    bg: "bg-[#1877F2]/10",
    text: "text-[#1877F2]",
    hover: "hover:bg-[#1877F2]/20",
  },
  instagram: {
    bg: "bg-pink-50",
    text: "text-pink-500",
    hover: "hover:bg-pink-100",
  },
  tiktok: {
    bg: "bg-gray-100",
    text: "text-gray-800",
    hover: "hover:bg-gray-200",
  },
  youtube: { bg: "bg-red-50", text: "text-red-500", hover: "hover:bg-red-100" },
  whatsapp: {
    bg: "bg-emerald-50",
    text: "text-emerald-600",
    hover: "hover:bg-emerald-100",
  },
  twitter: { bg: "bg-sky-50", text: "text-sky-500", hover: "hover:bg-sky-100" },
  website: {
    bg: "bg-violet-50",
    text: "text-violet-600",
    hover: "hover:bg-violet-100",
  },
};

const socialLabels: Record<string, string> = {
  facebook: "Facebook",
  instagram: "Instagram",
  tiktok: "TikTok",
  youtube: "YouTube",
  whatsapp: "WhatsApp",
  twitter: "Twitter / X",
  website: "Sitio web",
};

const waNumber = business.contact?.whatsapp?.replace(/\D/g, "");
const waLink = waNumber
  ? `https://wa.me/52${waNumber}?text=Hola,%20vi%20tu%20negocio%20en%20NicolásRomero.mx`
  : null;

const modelLabel: Record<string, string> = {
  physical: "Presencial",
  online: "En línea",
  both: "Presencial y en línea",
};

const galleryImages = business.gallery ?? [];
const heroImage = img(business.coverImage?.url);
const previewGallery = galleryImages.slice(0, 4);

// JSON-LD LocalBusiness para SEO
const siteOrigin = Astro.url.origin;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": business.name,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": business.location?.address ?? "",
    "addressLocality": "Nicolás Romero",
    "addressRegion": "Estado de México",
    "addressCountry": "MX"
  },
  "telephone": business.contact?.phone ?? "",
  "url": `${siteOrigin}/negocios/${business.slug}`,
  "image": heroImage
};
---

<Layout
  title={business.name}
  description={business.shortDescription || `Conoce ${business.name} en Nicolás Romero, Estado de México.`}
  ogImage={business.coverImage?.url}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <!-- ░░ HERO MOSAICO ░░ -->
  <div class="relative">
    <div class="absolute left-4 top-4 z-20 md:left-8">
      <a
        href="/explorar"
        class="inline-flex items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-md hover:shadow-lg transition-shadow"
      >
        <svg
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 19l-7-7 7-7"></path>
        </svg>
        Explorar
      </a>
    </div>

    {
      galleryImages.length >= 3 ? (
        <div class="hidden md:grid grid-cols-[2fr_1fr] gap-2 h-[480px] overflow-hidden rounded-none md:rounded-b-3xl">
          <div class="overflow-hidden">
            <img
              src={heroImage}
              alt={business.name}
              fetchpriority="high"
              class="h-full w-full object-cover hover:scale-[1.02] transition-transform duration-500 cursor-pointer"
              id="heroMain"
            />
          </div>
          <div class="grid grid-rows-2 gap-2">
            {previewGallery.slice(0, 2).map((g: any, i: number) => (
              <div class="overflow-hidden relative">
            <img
              src={img(g.url)}
              alt={`Foto ${i + 2}`}
              loading="lazy"
              class="h-full w-full object-cover hover:scale-[1.02] transition-transform duration-500 cursor-pointer gallery-thumb"
              data-index={i}
            />
                {i === 1 && galleryImages.length > 3 && (
                  <button
                    id="btnShowAll"
                    aria-label="Ver todas las fotos"
                    class="absolute inset-0 flex items-end justify-end p-3 cursor-pointer"
                  >
                    <span class="rounded-xl bg-white/90 backdrop-blur-sm px-3 py-1.5 text-xs font-semibold text-gray-800 shadow hover:bg-white transition-colors">
                      Ver todas las fotos ({galleryImages.length})
                    </span>
                  </button>
                )}
              </div>
            ))}
          </div>
        </div>
      ) : (
        <div class="hidden md:block h-[420px] overflow-hidden md:rounded-b-3xl">
          <img
            src={heroImage}
            alt={business.name}
            fetchpriority="high"
            class="h-full w-full object-cover"
          />
        </div>
      )
    }

    <div class="md:hidden h-64 overflow-hidden">
      <img
        src={heroImage}
        alt={business.name}
        fetchpriority="high"
        class="h-full w-full object-cover"
      />
    </div>
  </div>

  <!-- ░░ CONTENIDO PRINCIPAL ░░ -->
  <div class="mx-auto max-w-7xl px-4 py-8 md:py-10">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-[1fr_380px]">
      <!-- ── COLUMNA IZQUIERDA ── -->
      <div class="min-w-0 space-y-10">
        <!-- Header -->
        <div class="flex items-start gap-4 border-b border-gray-100 pb-8">
          <img
            src={img(business.logo?.url)}
            alt={`Logo de ${business.name}`}
            class="h-16 w-16 md:h-20 md:w-20 shrink-0 rounded-2xl border border-gray-100 object-cover shadow-sm"
          />
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-2 flex-wrap mb-1">
              {
                business.verified && (
                  <span class="inline-flex items-center gap-1 text-emerald-600 text-sm font-semibold">
                    <svg
                      class="h-3.5 w-3.5"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"
                      />
                    </svg>
                    Verificado
                  </span>
                )
              }
              {
                business.featured && (
                  <span class="text-amber-500 text-sm font-semibold">
                    ⭐ Destacado
                  </span>
                )
              }
            </div>
            <h1
              class="text-2xl md:text-4xl font-bold text-gray-900 leading-tight"
            >
              {business.name}
            </h1>
            <div
              class="mt-2 flex items-center gap-3 flex-wrap text-sm text-gray-500"
            >
              {
                business.area?.name && (
                  <span class="flex items-center gap-1">
                    🏪 {business.area.name}
                  </span>
                )
              }
              {
                business.location?.address && (
                  <span class="text-gray-400">
                    📍 {business.location.address}
                  </span>
                )
              }
            </div>
            <div class="mt-3 flex flex-wrap gap-2">
              {
                business.categories?.map((cat: any) => (
                  <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-600">
                    {cat.name}
                  </span>
                ))
              }
              <span
                class:list={[
                  "inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium",
                  business.active
                    ? "bg-emerald-50 text-emerald-700"
                    : "bg-gray-100 text-gray-500",
                ]}
              >
                <span
                  class:list={[
                    "h-1.5 w-1.5 rounded-full",
                    business.active ? "bg-emerald-500" : "bg-gray-400",
                  ]}></span>
                {business.active ? "Abierto ahora" : "Cerrado"}
              </span>
            </div>
          </div>
        </div>

        <!-- Atributos rápidos -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-2.5">
          {
            business.businessModel && (
              <div class="flex flex-col gap-1.5 rounded-xl border-l-[3px] border-l-primary bg-surface p-4">
                <svg
                  class="h-[18px] w-[18px] text-primary"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                  />
                </svg>
                <p class="text-[10px] font-medium uppercase tracking-widest text-muted">
                  Modalidad
                </p>
                <p class="text-sm font-semibold text-text">
                  {modelLabel[business.businessModel] ?? business.businessModel}
                </p>
              </div>
            )
          }

          <div
            class:list={[
              "flex flex-col gap-1.5 rounded-xl border-l-[3px] bg-surface p-4",
              business.acceptsCard ? "border-l-primary" : "border-l-gray-200",
            ]}
          >
            <svg
              class:list={[
                "h-[18px] w-[18px]",
                business.acceptsCard ? "text-primary" : "text-muted",
              ]}
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
              ></path>
            </svg>
            <p
              class="text-[10px] font-medium uppercase tracking-widest text-muted"
            >
              Pago
            </p>
            <p
              class:list={[
                "text-sm font-semibold",
                business.acceptsCard ? "text-text" : "text-muted",
              ]}
            >
              {business.acceptsCard ? "Efectivo y tarjeta" : "Solo efectivo"}
            </p>
          </div>

          <div
            class:list={[
              "flex flex-col gap-1.5 rounded-xl border-l-[3px] bg-surface p-4",
              business.homeDelivery ? "border-l-primary" : "border-l-gray-200",
            ]}
          >
            <svg
              class:list={[
                "h-[18px] w-[18px]",
                business.homeDelivery ? "text-primary" : "text-muted",
              ]}
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8l1 12h12l1-12"
              ></path>
            </svg>
            <p
              class="text-[10px] font-medium uppercase tracking-widest text-muted"
            >
              Delivery
            </p>
            <p
              class:list={[
                "text-sm font-semibold",
                business.homeDelivery ? "text-text" : "text-muted",
              ]}
            >
              {business.homeDelivery ? "Disponible" : "No disponible"}
            </p>
          </div>

          {
            todaySchedule && (
              <div
                class:list={[
                  "flex flex-col gap-1.5 rounded-xl border-l-[3px] bg-surface p-4",
                  todaySchedule.open && todaySchedule.close
                    ? "border-l-primary"
                    : "border-l-gray-200",
                ]}
              >
                <svg
                  class:list={[
                    "h-[18px] w-[18px]",
                    todaySchedule.open && todaySchedule.close
                      ? "text-primary"
                      : "text-muted",
                  ]}
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                  />
                </svg>
                <p class="text-[10px] font-medium uppercase tracking-widest text-muted">
                  Hoy — {todaySchedule.label}
                </p>
                <p
                  class:list={[
                    "text-sm font-semibold",
                    todaySchedule.open && todaySchedule.close
                      ? "text-text"
                      : "text-muted",
                  ]}
                >
                  {todaySchedule.open && todaySchedule.close
                    ? `${formatTime(todaySchedule.open)} – ${formatTime(todaySchedule.close)}`
                    : "Cerrado hoy"}
                </p>
                {todaySchedule.open && todaySchedule.close && (
                  <span class="inline-flex items-center gap-1.5 text-[11px] font-medium text-emerald-600 w-fit">
                    <span class="h-1.5 w-1.5 rounded-full bg-emerald-500" />
                    Abierto ahora
                  </span>
                )}
              </div>
            )
          }
        </div>
        <!-- Descripción -->
        {
          descParagraphs.length > 0 && (
            <div class="border-b border-gray-100 pb-10">
              <h2 class="text-lg font-semibold text-gray-900 mb-4">
                Acerca del negocio
              </h2>
              <div class="space-y-3">
                {descParagraphs.map((p: string) => (
                  <p class="text-sm leading-relaxed text-gray-600">{p}</p>
                ))}
              </div>
            </div>
          )
        }

        <!-- Galería -->
        {
          galleryImages.length > 0 && (
            <div class="border-b border-gray-100 pb-10">
              <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-gray-900">Fotos</h2>
                {galleryImages.length > 3 && (
                  <button
                    id="btnShowAll2"
                    aria-label="Ver todas las fotos"
                    class="cursor-pointer text-sm font-medium text-gray-500 underline underline-offset-2 hover:text-gray-800 transition-colors"
                  >
                    Ver todas ({galleryImages.length})
                  </button>
                )}
              </div>
              <div class="grid grid-cols-3 gap-2">
                {galleryImages.slice(0, 6).map((image: any, i: number) => (
                  <button
                    class="gallery-thumb group overflow-hidden rounded-xl aspect-square"
                    data-index={i}
                    aria-label={`Ver foto ${i + 1}`}
                  >
                    <img
                      src={img(image.url)}
                      alt={image.alternativeText ?? `Foto ${i + 1}`}
                      loading="lazy"
                      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105 cursor-pointer"
                    />
                  </button>
                ))}
              </div>
            </div>
          )
        }

        <!-- Horarios -->
        {
          business.schedule && (
            <div class="border-b border-gray-100 pb-10">
              <h2 class="text-lg font-semibold text-gray-900 mb-4">
                Horarios de atención
              </h2>
              <div class="rounded-2xl border border-gray-100 overflow-hidden">
                {DAYS.map(({ label, open, close }, i) => {
                  const isToday = dayMap[new Date().getDay()] === i;
                  return (
                    <div
                      class:list={[
                        "flex items-center justify-between px-5 py-3 text-sm",
                        isToday
                          ? "bg-emerald-50"
                          : i % 2 === 0
                            ? "bg-white"
                            : "bg-gray-50/40",
                      ]}
                    >
                      <span
                        class:list={[
                          "font-medium w-28",
                          isToday ? "text-emerald-700" : "text-gray-700",
                        ]}
                      >
                        {label}
                        {isToday && (
                          <span class="ml-2 text-[10px] font-semibold uppercase tracking-wide text-emerald-500">
                            hoy
                          </span>
                        )}
                      </span>
                      {open && close ? (
                        <span
                          class:list={[
                            isToday
                              ? "text-emerald-600 font-semibold"
                              : "text-gray-500",
                          ]}
                        >
                          {formatTime(open)} – {formatTime(close)}
                        </span>
                      ) : (
                        <span class="text-gray-300">Cerrado</span>
                      )}
                    </div>
                  );
                })}
              </div>
            </div>
          )
        }

        <!-- Ubicación -->
        {
          business.location?.address && (
            <div class="border-b border-gray-100 pb-10">
              <h2 class="text-lg font-semibold text-gray-900 mb-1">
                Dónde encontrarnos
              </h2>
              <p class="text-sm text-gray-500 mb-4 flex items-center gap-1.5">
                <svg
                  class="h-4 w-4 text-gray-400 shrink-0"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                  />
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                  />
                </svg>
                {business.location.address}
                {business.area?.name && `, ${business.area.name}`}
              </p>
             
{business.location.latitude && business.location.longitude && (
  <div
    id="bizMap"
    class="overflow-hidden rounded-2xl border border-gray-100 h-72 shadow-sm z-0"
    data-lat={business.location.latitude}
    data-lng={business.location.longitude}
  />
)}
            </div>
          )
        }
      </div>

      <!-- ── SIDEBAR STICKY ── -->
      <aside>
        <div class="sticky top-20 space-y-3">
          <!-- Card contacto -->
          <div
            class="rounded-3xl border border-gray-200 bg-white p-6 shadow-lg"
          >
            <div class="flex items-center justify-between mb-5">
              <div>
                <p
                  class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5"
                >
                  Estado actual
                </p>
                <span
                  class:list={[
                    "inline-flex items-center gap-1.5 text-sm font-semibold",
                    business.active ? "text-emerald-600" : "text-gray-400",
                  ]}
                >
                  <span
                    class:list={[
                      "h-2 w-2 rounded-full",
                      business.active
                        ? "bg-emerald-500 animate-pulse"
                        : "bg-gray-300",
                    ]}></span>
                  {business.active ? "Abierto ahora" : "Cerrado"}
                </span>
              </div>
              {
                business.verified && (
                  <span class="inline-flex items-center gap-1 rounded-full bg-emerald-50 px-2.5 py-1 text-[11px] font-semibold text-emerald-700">
                    <svg
                      class="h-3 w-3"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"
                      />
                    </svg>
                    Verificado
                  </span>
                )
              }
            </div>

