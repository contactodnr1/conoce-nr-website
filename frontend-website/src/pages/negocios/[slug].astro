---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import { getBusinessBySlug } from "../../services/businesses/getBusinessBySlug";

import BusinessHero from "../../components/business/BusinessHero.astro";
import BusinessHeader from "../../components/business/BusinessHeader.astro";
import BusinessAttributes from "../../components/business/BusinessAttributes.astro";
import BusinessDescription from "../../components/business/BusinessDescription.astro";
import BusinessGallery from "../../components/business/BusinessGallery.astro";
import BusinessSchedule from "../../components/business/BusinessSchedule.astro";
import BusinessMap from "../../components/business/BusinessMap.astro";
import BusinessContact from "../../components/business/BusinessContact.astro";
import BusinessSocialLinks from "../../components/business/BusinessSocialLinks.astro";
import GalleryModal from "../../components/business/GalleryModal.astro";
import WhatsAppFab from "../../components/business/WhatsAppFab.astro";

const { slug } = Astro.params;
const business = await getBusinessBySlug(slug!);

if (!business) return Astro.redirect("/404");

const STRAPI_URL = import.meta.env.PUBLIC_STRAPI_URL;

function img(url?: string | null): string {
  if (!url) return "/images/placeholder.svg";
  if (url.startsWith("http")) return url;
  return `${STRAPI_URL}${url}`;
}

const DAYS = [
  { label: "Lunes", open: business.schedule?.mondayOpen, close: business.schedule?.mondayClose },
  { label: "Martes", open: business.schedule?.tuesdayOpen, close: business.schedule?.tuesdayClose },
  { label: "Miércoles", open: business.schedule?.wednesdayOpen, close: business.schedule?.wednesdayClose },
  { label: "Jueves", open: business.schedule?.thursdayOpen, close: business.schedule?.thursdayClose },
  { label: "Viernes", open: business.schedule?.fridayOpen, close: business.schedule?.fridayClose },
  { label: "Sábado", open: business.schedule?.saturdayOpen, close: business.schedule?.saturdayClose },
  { label: "Domingo", open: business.schedule?.sundayOpen, close: business.schedule?.sundayClose },
];

const todayIndex = new Date().getDay();
const dayOrder = [6, 0, 1, 2, 3, 4, 5];
const todaySchedule = DAYS[dayOrder[todayIndex]];

const descParagraphs =
  business.description
    ?.filter((block: any) => block.children?.[0]?.text?.trim())
    .map((block: any) => block.children.map((c: any) => c.text).join("")) ?? [];

const socialEntries: [string, string][] = business.socialLinks
  ? (Object.entries(business.socialLinks).filter(
      ([k, v]) => k !== "id" && typeof v === "string" && v.trim(),
    ) as [string, string][])
  : [];

const waNumber = business.contact?.whatsapp?.replace(/\D/g, "");
const waLink = waNumber
  ? `https://wa.me/52${waNumber}?text=Hola,%20vi%20tu%20negocio%20en%20NicolásRomero.mx`
  : null;

const galleryImages = business.gallery ?? [];
const heroImage = img(business.coverImage?.url);

const siteOrigin = Astro.url.origin;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": business.name,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": business.location?.address ?? "",
    "addressLocality": "Nicolás Romero",
    "addressRegion": "Estado de México",
    "addressCountry": "MX"
  },
  "telephone": business.contact?.phone ?? "",
  "url": `${siteOrigin}/negocios/${business.slug}`,
  "image": heroImage
};
---

<Layout
  title={business.name}
  description={business.shortDescription || `Conoce ${business.name} en Nicolás Romero, Estado de México.`}
  ogImage={business.coverImage?.url}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <!-- Hero -->
  <div class="relative">
    <div class="absolute left-4 top-4 z-20 md:left-8">
      <a
        href="/explorar"
        class="inline-flex items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-md hover:shadow-lg transition-shadow"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Explorar
      </a>
    </div>

    <BusinessHero
      name={business.name}
      heroImage={heroImage}
      galleryImages={galleryImages}
    />
  </div>

  <!-- Contenido principal -->
  <div class="mx-auto max-w-7xl px-4 py-8 md:py-10">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-[1fr_380px]">
      <!-- Columna izquierda -->
      <div class="min-w-0 space-y-10">
        <BusinessHeader
          name={business.name}
          logo={business.logo}
          area={business.area}
          location={business.location}
          categories={business.categories}
          verified={business.verified}
          featured={business.featured}
          active={business.active}
        />

        <BusinessAttributes
          businessModel={business.businessModel}
          acceptsCard={business.acceptsCard}
          homeDelivery={business.homeDelivery}
          todaySchedule={todaySchedule}
        />

        <BusinessDescription paragraphs={descParagraphs} />

        <BusinessGallery images={galleryImages} />

        {
          business.schedule && (
            <div class="border-b border-gray-100 pb-10">
              <h2 class="text-lg font-semibold text-gray-900 mb-4">Horarios de atención</h2>
              <BusinessSchedule days={DAYS} />
            </div>
          )
        }

        <BusinessMap
          address={business.location?.address}
          areaName={business.area?.name}
          latitude={business.location?.latitude}
          longitude={business.location?.longitude}
        />
      </div>

      <!-- Sidebar sticky -->
      <aside>
        <div class="sticky top-20 space-y-3">
          <BusinessContact
            active={business.active}
            verified={business.verified}
            phone={business.contact?.phone}
            email={business.contact?.email}
            address={business.location?.address}
            waLink={waLink}
          />

          <BusinessSocialLinks entries={socialEntries} />
        </div>
      </aside>
    </div>
  </div>

  <GalleryModal show={galleryImages.length > 0} />

  <WhatsAppFab waLink={waLink} />
</Layout>

<script define:vars={{
    galleryUrls: business.gallery?.map((g: any) => g.url) ?? [],
    STRAPI_URL: import.meta.env.PUBLIC_STRAPI_URL,
  }} lang="ts"
>
  function resolveUrl(url) {
    if (!url) return "";
    return url.startsWith("http") ? url : STRAPI_URL + url;
  }

  const modal = document.getElementById("galleryModal");
  const modalImg = document.getElementById("modalImg");
  const modalCounter = document.getElementById("modalCounter");
  let current = 0;

  function showImage(index) {
    current = (index + galleryUrls.length) % galleryUrls.length;
    modalImg.src = resolveUrl(galleryUrls[current]);
    modalCounter.textContent = `${current + 1} / ${galleryUrls.length}`;
  }

  const modalFocusables = () => {
    const sel = "button, [href], input, select, textarea, [tabindex]:not([tabindex='-1'])";
    const els = modal.querySelectorAll(sel);
    return Array.from(els).filter((el) => el.offsetParent !== null);
  };

  function trapFocus(e) {
    const focusables = modalFocusables();
    if (focusables.length === 0) return;
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    if (e.key === "Tab") {
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  }

  function openModal(index) {
    showImage(index);
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    document.body.style.overflow = "hidden";
    const closeBtn = document.getElementById("btnCloseModal");
    closeBtn?.focus();
    document.addEventListener("keydown", trapFocus);
  }

  function closeModal() {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    document.body.style.overflow = "";
    document.removeEventListener("keydown", trapFocus);
  }

  document.querySelectorAll(".gallery-thumb").forEach((btn) => {
    btn.addEventListener("click", () => openModal(Number(btn.dataset.index)));
  });

  document.getElementById("heroMain")?.addEventListener("click", () => openModal(0));
  document.getElementById("btnShowAll")?.addEventListener("click", () => openModal(0));
  document.getElementById("btnShowAll2")?.addEventListener("click", () => openModal(0));
  document.getElementById("btnCloseModal")?.addEventListener("click", closeModal);
  document.getElementById("btnPrev")?.addEventListener("click", () => showImage(current - 1));
  document.getElementById("btnNext")?.addEventListener("click", () => showImage(current + 1));
  modal?.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener("keydown", (e) => {
    if (!modal?.classList.contains("flex")) return;
    if (e.key === "Escape") closeModal();
    if (e.key === "ArrowLeft") showImage(current - 1);
    if (e.key === "ArrowRight") showImage(current + 1);
  });

  document.getElementById("btnShare")?.addEventListener("click", async () => {
    try {
      await navigator.share({
        title: document.title,
        url: window.location.href,
      });
    } catch {
      await navigator.clipboard.writeText(window.location.href);
    }
  });
</script>
