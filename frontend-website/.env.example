# URL del CMS Strapi (producción)
# En desarrollo usar: http://localhost:1337
PUBLIC_STRAPI_URL=https://strapi.railway.app

## Variables de entorno
# PUBLIC_STRAPI_URL: URL base del CMS Strapi
#   - Local:    http://localhost:1337
#   - Producción: https://strapi.tudominio.com
#
# NOTA: Solo las variables con prefijo PUBLIC_ se exponen al cliente.
# No uses PUBLIC_ para tokens o secretos.
